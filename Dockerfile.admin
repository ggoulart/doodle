# syntax=docker/dockerfile:1

FROM eclipse-temurin:26-jdk AS build
WORKDIR /workspace
COPY gradlew settings.gradle ./
COPY gradle gradle
COPY api api
COPY admin admin
RUN ./gradlew :admin:bootJar --no-daemon

FROM eclipse-temurin:26-jre
WORKDIR /app
COPY --from=build /workspace/admin/build/libs/admin.jar doodle-admin.jar
EXPOSE 8081
ENTRYPOINT ["java", "-jar", "doodle-admin.jar"]
